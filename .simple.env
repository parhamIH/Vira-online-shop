# تنظیمات دیتابیس
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_super_secret_database_password
DB_HOST=localhost
DB_PORT=0000

# تنظیمات زرین‌پال
ZARINPAL_MERCHANT_ID=your_zarinpal_merchant_id
ZARINPAL_SANDBOX=True  # یا False برای محیط پروداکشن

# تنظیمات امنیتی
SECRET_KEY=your_very_very_secret_django_secret_key_change_this
ALLOWED_HOSTS=["localhost", "127.0.0.1", "yourdomain.com"] # این یک لیست پایتون است
